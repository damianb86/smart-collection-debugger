# Smart Collection Debugger
# Copy to .env for local development. Do not commit real secrets.

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://example.com
SCOPES=read_products
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/smart_collection_debugger
SHOP_CUSTOM_DOMAIN=
NODE_ENV=development

# Docker deployment placeholders
COMPOSE_PROJECT_NAME=smart-collection-debugger
APP_DB_NAME=smart_collection_debugger
APP_DB_USER=smart_collection_debugger_user
APP_DB_PASSWORD=replace_me
APP_HOST=smart-collection-debugger.example.com
CONTACT_EMAIL=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
NODE_OPTIONS=
